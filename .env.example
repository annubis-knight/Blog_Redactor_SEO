# Blog Redactor SEO — Environment Variables
# Copy this file to .env and fill in your values


# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx

# DataForSEO API
DATAFORSEO_LOGIN=your-email@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
# Use sandbox (free, unlimited, fake data) — auto-enabled in dev, set to 'false' to opt-out
DATAFORSEO_SANDBOX=true
# Minimum hours between keyword refresh (default: 168 in prod, 0 in dev)
# DATAFORSEO_MIN_REFRESH_HOURS=168

# Web search during article generation (true/false, default: true)
# WEB_SEARCH_ENABLED=true

# Claude model to use for generation
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Tavily API (content gap analysis)
TAVILY_API_KEY=tvly-xxx

# Google Search Console OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3005/api/gsc/callback

# Backend server port
PORT=3005
