# Blog Redactor SEO — Environment Variables
# Copy this file to .env and fill in your values


# --- AI provider switch --------------------------------------------------
# 'claude'     = Anthropic (production)
# 'gemini'     = Google (dev, gratuit mais ~15 req/min)
# 'openrouter' = OpenRouter (dev, catalogue de modèles :free)
# 'mock'       = Provider simulé local (pas de réseau, fixtures déterministes)
#
# Fallback auto sur quota/overload : primary → claude → gemini → openrouter
# (le mock n'entre jamais dans la chaîne — c'est un provider explicite).
# Désactiver le fallback : 
AI_PROVIDER_NO_FALLBACK=1
# Par défaut : 'claude'
AI_PROVIDER=claude

# Mock provider (AI_PROVIDER=mock) — latence simulée en ms (défaut 200)
# MOCK_LATENCY_MS=200

# Claude API (Anthropic) — requis si AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-xxx

# Gemini API (Google) — requis si AI_PROVIDER=gemini
VITE_GEMINI_API_KEY=AIzaSy-xxx
GEMINI_PROJET_NAME=projects/000000000000
GEMINI_PROJET_ID=000000000000

# OpenRouter — requis si AI_PROVIDER=openrouter
# N'utilisez QUE des modèles gratuits (suffixe obligatoire `:free`).
OPEN_ROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# DataForSEO API
DATAFORSEO_LOGIN=your-email@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
# Use sandbox (free, fake data). MUST be opt-in explicitly — sans cette variable
# le service tape la prod et consomme des crédits.
DATAFORSEO_SANDBOX=true
# Plafond de coût par fenêtre glissante (défaut: 0.50 USD / 30 min)
# DATAFORSEO_COST_BUDGET_USD=0.50
# DATAFORSEO_COST_WINDOW_MIN=30
# Minimum hours between keyword refresh (default: 168 in prod, 0 in dev)
# DATAFORSEO_MIN_REFRESH_HOURS=168

# Web search during article generation (true/false, default: true)
# WEB_SEARCH_ENABLED=true

# Claude model to use for generation (utilisé uniquement si AI_PROVIDER=claude)
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gemini model (utilisé uniquement si AI_PROVIDER=gemini).
# Les modèles Flash sont gratuits mais rate-limited (15 req/min sur free tier).
# GEMINI_MODEL=gemini-2.0-flash        # par défaut (rapide + gratuit)
# GEMINI_MODEL=gemini-2.0-flash-lite   # encore plus rapide (gratuit)
# GEMINI_MODEL=gemini-2.5-flash        # plus récent (raisonnement, payant)
# GEMINI_MODEL=gemini-2.5-pro          # pour les tâches complexes (payant)
GEMINI_MODEL=gemini-2.0-flash

# Tavily API (content gap analysis)
TAVILY_API_KEY=tvly-xxx

# Google Search Console OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3005/api/gsc/callback

# Backend server port
PORT=3005

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=blog_redactor_seo
